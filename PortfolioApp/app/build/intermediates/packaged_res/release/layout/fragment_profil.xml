<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/light_gray">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">
        <LinearLayout android:layout_width="match_parent" android:layout_height="220dp"
            android:background="@drawable/splash_bg" android:orientation="vertical"
            android:gravity="center" android:padding="24dp">
            <ImageView android:layout_width="90dp" android:layout_height="90dp"
                android:background="@drawable/circle_photo"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/white" android:padding="20dp"
                android:scaleType="centerInside"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Mohamed Kebe" android:textColor="@color/white"
                android:textSize="22sp" android:textStyle="bold" android:layout_marginTop="12dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Data and Software Engineer" android:textColor="#B0C4DE" android:textSize="14sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📍 Rabat, Maroc" android:textColor="#B0C4DE"
                android:textSize="12sp" android:layout_marginTop="4dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@color/white" android:orientation="horizontal"
            android:padding="16dp" android:gravity="center">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@color/progress_bg" android:padding="8dp"
                    android:src="@android:drawable/ic_menu_myplaces"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Parcours" android:textSize="11sp" android:textColor="@color/text_secondary" android:layout_marginTop="4dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@color/progress_bg" android:padding="8dp"
                    android:src="@android:drawable/ic_menu_info_details"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Skills" android:textSize="11sp" android:textColor="@color/text_secondary" android:layout_marginTop="4dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@color/progress_bg" android:padding="8dp"
                    android:src="@android:drawable/ic_menu_agenda"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Projets" android:textSize="11sp" android:textColor="@color/text_secondary" android:layout_marginTop="4dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@color/progress_bg" android:padding="8dp"
                    android:src="@android:drawable/ic_menu_call"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Contact" android:textSize="11sp" android:textColor="@color/text_secondary" android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@color/white" android:orientation="vertical"
            android:padding="20dp" android:layout_marginTop="8dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="À propos" android:textSize="18sp" android:textStyle="bold"
                android:textColor="@color/text_primary" android:layout_marginBottom="8dp"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Élève Ingénieur en Data &amp; Software Engineering à l'INSEA, Fullstack Developer et Fondateur de Wonkhaï.\n\nPassionné par l'architecture logicielle et l'exploitation des données, je conjugue une formation académique rigoureuse avec une expérience pratique du développement de solutions scalables. Actuellement concentré sur Wonkhaï, une Super-App ambitieuse, je maîtrise des technologies de pointe comme Elixir, Flutter et React Native.\n\nExpertise clé :\n• Développement Mobile &amp; Cross-Platform (Flutter, React Native)\n• Ingénierie Backend (Elixir, Phoenix, systèmes distribués)\n• Data Science &amp; Text Mining (NLP, Scikit-learn, MongoDB)\n• Esprit Entrepreneurial (Lead développeur de Wonkhaï)\n\nStack technique : Elixir, Java, Python, Flutter, React Native, API REST, JWT."
                android:textSize="14sp" android:textColor="@color/text_secondary" android:lineSpacingMultiplier="1.5"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@color/white" android:orientation="vertical"
            android:padding="20dp" android:layout_marginTop="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Derniers Projets"
                    android:textSize="18sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="24sp" android:textColor="@color/blue_primary"/>
            </LinearLayout>
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content"
                card_view:cardCornerRadius="10dp" card_view:cardElevation="3dp"
                android:layout_marginTop="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <View android:layout_width="match_parent" android:layout_height="100dp" android:background="@drawable/card_project_bg"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Application Portfolio" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Application Android de portfolio personnel"
                            android:textSize="12sp" android:textColor="@color/text_secondary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Java • Android" android:textSize="11sp" android:textColor="@color/blue_primary"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:padding="16dp" android:layout_marginTop="8dp">
            <Button android:id="@+id/btnQRCode"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:text="Mon QR Code" android:backgroundTint="@color/navy_dark" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnRDV"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:text="Rendez-Vous" android:backgroundTint="@color/blue_primary"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>

