<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Prendre un Rendez-vous"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />
        
        <CalendarView
            android:id="@+id/calendarView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Créneaux disponibles :"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            
            <Button
                android:id="@+id/btn10h"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="10:00"
                android:layout_marginEnd="8dp" />
            
            <Button
                android:id="@+id/btn1130"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="11:30"
                android:layout_marginEnd="8dp" />
            
            <Button
                android:id="@+id/btn14h"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="14:00" />
        </LinearLayout>
        
        <EditText
            android:id="@+id/rdv_name"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Votre nom"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:inputType="text" />
        
        <EditText
            android:id="@+id/rdv_email"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Votre email"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:inputType="textEmailAddress" />
        
        <EditText
            android:id="@+id/rdv_phone"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Votre téléphone"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:inputType="phone" />
        
        <EditText
            android:id="@+id/rdv_subject"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Sujet de la réunion"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:inputType="text" />
        
        <Button
            android:id="@+id/btnConfirmer"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Confirmer" />
        
    </LinearLayout>
    
</ScrollView>
